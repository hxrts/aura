module session_patterns exposing (SimpleSessionChoreography)

protocol SimpleSessionChoreography =
  roles Coordinator, Participants[*]

  -- Phase 1: Coordinator invites participants
  Coordinator { parallel = true
              , guard_capability = "create_session"
              , flow_cost = 100
              , journal_facts = "session_created" }
    -> Participants[*] : SessionInvitation of crate.SessionInvitation

  -- Phase 2: Participants decide to accept or decline
  choice at Participants[*]
    | accept ->
        Participants[*] { parallel = true
                        , guard_capability = "join_session"
                        , flow_cost = 50
                        , journal_facts = "session_joined" }
          -> Coordinator : SessionAccepted of crate.SessionAccepted

    | decline ->
        Participants[*] { parallel = true
                        , guard_capability = "decline_session"
                        , flow_cost = 25
                        , journal_facts = "session_declined" }
          -> Coordinator : SessionDeclined of crate.SessionDeclined

  -- Phase 3: Activate session
  Coordinator { parallel = true
              , guard_capability = "activate_session"
              , flow_cost = 75
              , journal_facts = "session_activated" }
    -> Participants[*] : SessionActivated of crate.SessionActivated

  -- Phase 4: Session loop
  loop decide by Coordinator
    choice at Coordinator
      | broadcast ->
          Coordinator { parallel = true
                       , guard_capability = "broadcast_message"
                       , flow_cost = 25 }
            -> Participants[*] : BroadcastMessage of crate.BroadcastMessage

      | status_check ->
          Coordinator { parallel = true
                       , guard_capability = "check_status"
                       , flow_cost = 10 }
            -> Participants[*] : StatusCheck of crate.StatusCheck

          Participants[*] { parallel = true
                          , guard_capability = "report_status"
                          , flow_cost = 15 }
            -> Coordinator : StatusReport of crate.StatusReport

      | end_session ->
          Coordinator { parallel = true
                       , guard_capability = "end_session"
                       , flow_cost = 100
                       , journal_facts = "session_ended" }
            -> Participants[*] : SessionEnded of crate.SessionEnded
