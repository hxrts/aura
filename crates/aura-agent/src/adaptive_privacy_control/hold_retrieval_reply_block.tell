module hold_retrieval_reply_block exposing (HoldRetrievalReplyBlockProtocol)

protocol HoldRetrievalReplyBlockProtocol =
  roles Retriever, Verifier

  Retriever { guard_capability = "adaptive_privacy:reply_block:hold_retrieval:submit_witness"
            , flow_cost = 15
            , journal_facts = "hold_retrieval_witness_submitted" }
    -> Verifier : HoldRetrievalWitnessSubmission of crate.adaptive_privacy_control.HoldRetrievalWitnessSubmission

  choice at Verifier
    | Accepted ->
        Verifier { guard_capability = "adaptive_privacy:reply_block:hold_retrieval:accept_witness"
                 , flow_cost = 10
                 , journal_facts = "hold_retrieval_witness_accepted" }
          -> Retriever : HoldRetrievalWitnessAccepted of crate.adaptive_privacy_control.HoldRetrievalWitnessAccepted

    | Rejected ->
        Verifier { guard_capability = "adaptive_privacy:reply_block:hold_retrieval:reject_witness"
                 , flow_cost = 10
                 , journal_facts = "hold_retrieval_witness_rejected" }
          -> Retriever : HoldRetrievalWitnessRejected of crate.adaptive_privacy_control.HoldRetrievalWitnessRejected
