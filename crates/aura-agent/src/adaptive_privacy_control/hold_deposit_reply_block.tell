module hold_deposit_reply_block exposing (HoldDepositReplyBlockProtocol)

protocol HoldDepositReplyBlockProtocol =
  roles Depositor, Verifier

  Depositor { guard_capability = "adaptive_privacy:reply_block:hold_deposit:submit_witness"
            , flow_cost = 15
            , journal_facts = "hold_deposit_witness_submitted" }
    -> Verifier : HoldDepositWitnessSubmission of crate.adaptive_privacy_control.HoldDepositWitnessSubmission

  choice at Verifier
    | Accepted ->
        Verifier { guard_capability = "adaptive_privacy:reply_block:hold_deposit:accept_witness"
                 , flow_cost = 10
                 , journal_facts = "hold_deposit_witness_accepted" }
          -> Depositor : HoldDepositWitnessAccepted of crate.adaptive_privacy_control.HoldDepositWitnessAccepted

    | Rejected ->
        Verifier { guard_capability = "adaptive_privacy:reply_block:hold_deposit:reject_witness"
                 , flow_cost = 10
                 , journal_facts = "hold_deposit_witness_rejected" }
          -> Depositor : HoldDepositWitnessRejected of crate.adaptive_privacy_control.HoldDepositWitnessRejected
