module session_coordination exposing (SessionCoordinationChoreography)

protocol SessionCoordinationChoreography =
  roles Initiator, Participants[N], Coordinator

  -- Phase 1: Session request
  Initiator { guard_capability = "request_session"
            , flow_cost = 100
            , journal_facts = "session_requested" }
    -> Coordinator : SessionRequest of crate.handlers.sessions.coordination.SessionRequest

  -- Phase 2: Coordinator invites participants
  Coordinator { parallel = true
              , guard_capability = "invite_participants"
              , flow_cost = 50
              , journal_facts = "participants_invited" }
    -> Participants[*] : ParticipantInvitation of crate.handlers.sessions.coordination.ParticipantInvitation

  -- Phase 3: Participants respond
  Participants[*] { parallel = true
                  , guard_capability = "respond_session"
                  , flow_cost = 75
                  , journal_facts = "session_responded" }
    -> Coordinator : SessionDecision of crate.handlers.sessions.coordination.SessionDecision

  -- Phase 4: Coordinator decides outcome
  choice at Coordinator
    | Success ->
        Coordinator { guard_capability = "create_session"
                    , flow_cost = 200
                    , journal_facts = "session_created"
                    , journal_merge = true }
          -> Initiator : SessionCreated of crate.handlers.sessions.coordination.SessionCreated

        Coordinator { parallel = true
                    , guard_capability = "notify_participants"
                    , flow_cost = 100
                    , journal_facts = "session_participants_notified" }
          -> Participants[*] : SessionCreated of crate.handlers.sessions.coordination.SessionCreated

    | Failure ->
        Coordinator { guard_capability = "reject_session_creation"
                    , flow_cost = 100
                    , journal_facts = "session_creation_failed" }
          -> Initiator : SessionCreationFailed of crate.handlers.sessions.coordination.SessionCreationFailed

        Coordinator { parallel = true
                    , guard_capability = "notify_participants_failure"
                    , flow_cost = 50
                    , journal_facts = "session_failure_notified" }
          -> Participants[*] : SessionCreationFailed of crate.handlers.sessions.coordination.SessionCreationFailed
