{
  "name": "aura-web-style",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "tailwind:build": "mkdir -p ./public/assets && BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -c tailwind.config.cjs -i ./styles/app.css -o ./public/assets/tailwind.css --minify",
    "tailwind:watch": "mkdir -p ./public/assets && BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -c tailwind.config.cjs -i ./styles/app.css -o ./public/assets/tailwind.css --watch --poll"
  },
  "devDependencies": {
    "esbuild": "0.27.4",
    "tailwindcss": "3.4.17",
    "ws": "8.18.3"
  }
}
